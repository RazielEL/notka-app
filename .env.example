# Required in Docker/production. Generate with:
# openssl rand -base64 48
SESSION_SECRET=

# Set to true only when serving Notka over HTTPS.
# Keep false for private HTTP over Tailscale.
SESSION_COOKIE_SECURE=false

# Docker uses /data. Local development defaults to ./data via package scripts.
DATA_DIR=/data

# Optional. Defaults to $DATA_DIR/app.db.
# SQLITE_DB_PATH=/data/app.db
