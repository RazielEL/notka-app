# Host port exposed by Docker Compose.
NOTKA_HOST_PORT=13379

# Required in Docker/production. Generate with:
# openssl rand -base64 48
SESSION_SECRET=

# Set to true only when serving Notka over HTTPS.
# Keep false for private HTTP over Tailscale.
SESSION_COOKIE_SECURE=false

# Persistent data directory inside the container.
DATA_DIR=/data
